			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label=Lex];
		"https://w3id.org/min#Norma"	[color="#2B6CB0",
			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label=Norma];
		"https://w3id.org/min#Object"	[color="#2B6CB0",
			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label=Object];
		"https://w3id.org/min#Possibile"	[color="#2B6CB0",
			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label=Possibile];
		"https://w3id.org/min#Process"	[color="#2B6CB0",
			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label=Process];
		"https://w3id.org/min#Structura"	[color="#2B6CB0",
			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label=Structura];
	}
	"https://w3id.org/sdata/core/EnvironmentAgent"	[color="#6B46C1",
