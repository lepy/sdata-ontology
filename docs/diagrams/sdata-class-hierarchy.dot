digraph "" {
	graph [bgcolor="#FAFBFC",
		fontname=Helvetica,
		fontsize=20,
		label="sdata Class Hierarchy (core v0.15.0 / MIN v3.7 based)",
		labeljust=c,
		labelloc=t,
		nodesep=0.55,
		overlap=false,
		pad=0.35,
		rankdir=TB,
		ranksep=1.0,
		splines=true
	];
	node [fontname=Helvetica,
		fontsize=12,
		label="\N",
		margin="0.14,0.08",
		penwidth=1.6,
		shape=box,
		style="filled,rounded"
	];
	edge [arrowsize=0.85,
		color="#4A5568",
		fontname=Helvetica,
		penwidth=1.6
	];
	subgraph cluster_legend {
		graph [color="#CBD5E0",
			label=Legend,
			style=rounded
		];
		legend_min	[color="#2B6CB0",
			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label="MIN class"];
		legend_sdata	[color="#6B46C1",
			fillcolor="#E8F1FF",
			fontcolor="#44337A",
			label="sdata class"];
		legend_min -> legend_sdata	[label="superclass -> subclass"];
	}
	subgraph min_rank {
		graph [rank=same,
			style=invis
		];
		"https://w3id.org/min#Agent"	[color="#2B6CB0",
			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label=Agent];
		"https://w3id.org/min#Boundary"	[color="#2B6CB0",
			fillcolor="#E7F0FF",
			fontcolor="#1A365D",
			label=Boundary];
