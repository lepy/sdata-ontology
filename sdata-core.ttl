@prefix sdata:   <https://w3id.org/sdata/core/> .
@prefix min:     <https://w3id.org/min#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .

# =============================================================================
#
#   sdata — Semantic Data Ontology (Core)
#
#   v0.1.0 — 2026-03-08
#
#   48 Klassen. 30 eigene Object Properties + 45 OP-Fassaden.
#   18 eigene Datatype Properties + 5 DP-Fassaden + 2 AP-Fassaden.
#
#   NAMESPACE-REGEL:
#     Domänennutzer schreiben ausschließlich sdata:*.
#     MIN existiert als importierte Architektur-Ontologie.
#     Alle MIN-Relationen sind als sdata:-Äquivalente verfügbar.
#     MIN-Namespace ist nur für Ontologie-Architekten relevant.
#
#   KLASSE-VS-TYPUS-REGEL:
#     Bringt der Kandidat ein neues strukturelles Axiom?
#       Ja  → Klasse
#       Nein → Typus-Instanz
#
#   AGENT-DESIGN:
#     Zustand ≠ Typ. Ob ein Agent gerade aktiv ist,
#     gehört in sdata:hasStatus, nicht in die Klassenhierarchie.
#
#     Agent-Co-Typisierungen:
#       Person:           Agent ∩ Object      (materiale Identität)
#       Hardware:         Agent ∩ Object      (materiale Identität)
#       Material:         Agent ∩ Object      (materiale Identität)
#       Substance:        Agent ∩ Object      (materiale Identität)
#       Specimen:         Agent ∩ Object      (materiale Identität)
#       Software:         Agent ∩ Data        (informationale Identität)
#       DigitalTwin:      ⊂ Software          (informationale Identität)
#       Organization:     Agent ∩ Institutio  (institutionelle Identität)
#       EnvironmentAgent: Agent ∩ Process     (kausale Identität)
#
#   PRODUCT-DESIGN:
#     "Ist ein Produkt" ist eine institutionelle Zuschreibung,
#     keine ontologische Klasse. Modellierung über
#     sdata:typifiedBy → sdata:ProductType.
#
#   DOKUMENT/DATEI-DESIGN:
#     "Ist ein Dokument/Datei" ist keine Klasse.
#     Persistierungsformat über sdata:typifiedBy → sdata:DataFormat.
#     ResultFile eliminiert — Data + DataFormat reicht.
#
# =============================================================================

<https://w3id.org/sdata/core> a owl:Ontology ;
    owl:versionIRI <https://w3id.org/sdata/core/0.1.0> ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://w3id.org/min> ;
    dcterms:title "sdata — Semantic Data Ontology (Core)"@en ;
    dcterms:title "sdata — Semantische Datenontologie (Kern)"@de ;
    dcterms:description """Domänenontologie für Materialwissenschaft,
    Fertigungstechnik, Produktpässe, Kreislaufwirtschaft,
    Digitale Zwillinge, LCA und Verifiable Credentials.

    Architektur: MIN v1.0.0 (Grundontologie) → sdata (Domäne).
    Nutzer arbeiten ausschließlich mit sdata:-Termen.

    48 Klassen über alle MIN-Kategorien:
      Fassaden (7), Object (1), Data (10), Agent (9), Process (1),
      Boundary (1), Lex (1), Structura (1), Possibile (1), Norma (1),
      Institutio (9), Typus (6).

    Agent-Design: Zustand ≠ Typ. Hardware, Software, Material,
    Substance, Specimen, DigitalTwin sind immer Agents.
    Product und ResultFile sind keine Klassen sondern Rollen."""@de ;
    dcterms:creator <https://orcid.org/0000-0001-8199-8666> ;
    dcterms:created "2026-03-08"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
    rdfs:seeAlso <https://w3id.org/min> ;
    min:designRationale """v0.1.0 — Konformität mit MIN v1.0.0.
    Agent-Design: Zustand ≠ Typ.
    Product eliminiert — Rolle via ProductType.
    ResultFile eliminiert — Data + DataFormat.
    hasFormat eliminiert — typifiedBy DataFormat.
    Material → Agent ∩ Object.
    DigitalTwin ⊂ Software (Agent ∩ Data).
    Substance, Specimen → Agent ∩ Object.
    """@de .
<https://orcid.org/0000-0001-8199-8666> a foaf:Person ;
    foaf:name "Dr. Ingolf Lepenies" ;
    foaf:homepage <https://github.com/lepy> .


# #############################################################################
#
#   TEIL I — MIN-RELATIONEN ALS sdata:-FASSADEN
#
#   45 Object-Property-Fassaden, 5 Datatype-Property-Fassaden,
#   2 Annotation-Property-Fassaden.
#
# #############################################################################

# --- Inter-Nexus ---

sdata:nexusWith a owl:ObjectProperty ;
    owl:equivalentProperty min:nexusWith ;
    rdfs:label "nexus with"@en ;
    rdfs:label "verbunden mit"@de .

sdata:hasComponent a owl:ObjectProperty ;
    owl:equivalentProperty min:hasComponent ;
    rdfs:label "has component"@en ;
    rdfs:label "hat Bestandteil"@de .

sdata:derivedFrom a owl:ObjectProperty ;
    owl:equivalentProperty min:derivedFrom ;
    rdfs:label "derived from"@en ;
    rdfs:label "abgeleitet von"@de .

# --- Kategorienrelationen: Process ↔ Nexus ---

sdata:hasInput a owl:ObjectProperty ;
    owl:equivalentProperty min:hasInput ;
    rdfs:label "has input"@en ;
    rdfs:label "hat Eingabe"@de .

sdata:hasOutput a owl:ObjectProperty ;
    owl:equivalentProperty min:hasOutput ;
    rdfs:label "has output"@en ;
    rdfs:label "hat Ausgabe"@de .

sdata:undergoes a owl:ObjectProperty ;
    owl:equivalentProperty min:undergoes ;
    rdfs:label "undergoes"@en ;
    rdfs:label "durchläuft"@de .

sdata:resultOf a owl:ObjectProperty ;
    owl:equivalentProperty min:resultOf ;
    rdfs:label "result of"@en ;
    rdfs:label "Ergebnis von"@de .

# --- Kategorienrelationen: Agent ↔ Process ---

sdata:performs a owl:ObjectProperty ;
    owl:equivalentProperty min:performs ;
    rdfs:label "performs"@en ;
    rdfs:label "führt durch"@de .

sdata:performedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:performedBy ;
    rdfs:label "performed by"@en ;
    rdfs:label "durchgeführt von"@de .

sdata:controls a owl:ObjectProperty ;
    owl:equivalentProperty min:controls ;
    rdfs:label "controls"@en ;
    rdfs:label "steuert"@de .

# --- Kategorienrelationen: Agent ↔ Object ---

sdata:actsOn a owl:ObjectProperty ;
    owl:equivalentProperty min:actsOn ;
    rdfs:label "acts on"@en ;
    rdfs:label "wirkt auf"@de .

sdata:affectedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:affectedBy ;
    rdfs:label "affected by"@en ;
    rdfs:label "betroffen von"@de .

sdata:owns a owl:ObjectProperty ;
    owl:equivalentProperty min:owns ;
    rdfs:label "owns"@en ;
    rdfs:label "besitzt"@de .

# --- Kategorienrelationen: Data ---

sdata:describes a owl:ObjectProperty ;
    owl:equivalentProperty min:describes ;
    rdfs:label "describes"@en ;
    rdfs:label "beschreibt"@de .

sdata:describedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:describedBy ;
    rdfs:label "described by"@en ;
    rdfs:label "beschrieben durch"@de .

sdata:generates a owl:ObjectProperty ;
    owl:equivalentProperty min:generates ;
    rdfs:label "generates"@en ;
    rdfs:label "erzeugt"@de .

sdata:generatedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:generatedBy ;
    rdfs:label "generated by"@en ;
    rdfs:label "erzeugt durch"@de .

sdata:produces a owl:ObjectProperty ;
    owl:equivalentProperty min:produces ;
    rdfs:label "produces"@en ;
    rdfs:label "produziert"@de .

# --- Kategorienrelationen: Boundary ---

sdata:bounds a owl:ObjectProperty ;
    owl:equivalentProperty min:bounds ;
    rdfs:label "bounds"@en ;
    rdfs:label "begrenzt"@de .

sdata:hasBoundary a owl:ObjectProperty ;
    owl:equivalentProperty min:hasBoundary ;
    rdfs:label "has boundary"@en ;
    rdfs:label "hat Grenze"@de .

# --- Kategorienrelationen: Agent → Possibile ---

sdata:selects a owl:ObjectProperty ;
    owl:equivalentProperty min:selects ;
    rdfs:label "selects"@en ;
    rdfs:label "wählt"@de .

# --- Allgemeine Nexus-Relationen ---

sdata:influences a owl:ObjectProperty ;
    owl:equivalentProperty min:influences ;
    rdfs:label "influences"@en ;
    rdfs:label "beeinflusst"@de .

sdata:expresses a owl:ObjectProperty ;
    owl:equivalentProperty min:expresses ;
    rdfs:label "expresses"@en ;
    rdfs:label "drückt aus"@de .

sdata:between a owl:ObjectProperty ;
    owl:equivalentProperty min:between ;
    rdfs:label "between"@en ;
    rdfs:label "zwischen"@de .

# --- Brückenrelationen: Nexus → Forma (Genese) ---

sdata:originates a owl:ObjectProperty ;
    owl:equivalentProperty min:originates ;
    rdfs:label "originates"@en ;
    rdfs:label "bringt hervor"@de .

sdata:originatedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:originatedBy ;
    rdfs:label "originated by"@en ;
    rdfs:label "hervorgebracht durch"@de .

# --- Brückenrelationen: Nexus → Forma (Realisierung) ---

sdata:realizes a owl:ObjectProperty ;
    owl:equivalentProperty min:realizes ;
    rdfs:label "realizes"@en ;
    rdfs:label "realisiert"@de .

sdata:realizedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:realizedBy ;
    rdfs:label "realized by"@en ;
    rdfs:label "realisiert durch"@de .

# --- Brückenrelationen: Forma → Nexus (Bestimmung) ---

sdata:constrains a owl:ObjectProperty ;
    owl:equivalentProperty min:constrains ;
    rdfs:label "constrains"@en ;
    rdfs:label "beschränkt"@de .

sdata:governs a owl:ObjectProperty ;
    owl:equivalentProperty min:governs ;
    rdfs:label "governs"@en ;
    rdfs:label "regiert"@de .

sdata:formalizes a owl:ObjectProperty ;
    owl:equivalentProperty min:formalizes ;
    rdfs:label "formalizes"@en ;
    rdfs:label "formalisiert"@de .

sdata:evaluates a owl:ObjectProperty ;
    owl:equivalentProperty min:evaluates ;
    rdfs:label "evaluates"@en ;
    rdfs:label "bewertet"@de .

sdata:concerns a owl:ObjectProperty ;
    owl:equivalentProperty min:concerns ;
    rdfs:label "concerns"@en ;
    rdfs:label "betrifft"@de .

sdata:alternativeTo a owl:ObjectProperty ;
    owl:equivalentProperty min:alternativeTo ;
    rdfs:label "alternative to"@en ;
    rdfs:label "Alternative zu"@de .

# --- Brückenrelationen: Agent → Institutio ---

sdata:constitutes a owl:ObjectProperty ;
    owl:equivalentProperty min:constitutes ;
    rdfs:label "constitutes"@en ;
    rdfs:label "konstituiert"@de .

sdata:constitutedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:constitutedBy ;
    rdfs:label "constituted by"@en ;
    rdfs:label "konstituiert durch"@de .

sdata:recognizes a owl:ObjectProperty ;
    owl:equivalentProperty min:recognizes ;
    rdfs:label "recognizes"@en ;
    rdfs:label "erkennt an"@de .

sdata:recognizedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:recognizedBy ;
    rdfs:label "recognized by"@en ;
    rdfs:label "anerkannt durch"@de .

# --- Brückenrelationen: Data → Forma ---

sdata:encodes a owl:ObjectProperty ;
    owl:equivalentProperty min:encodes ;
    rdfs:label "encodes"@en ;
    rdfs:label "kodiert"@de .

sdata:encodedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:encodedBy ;
    rdfs:label "encoded by"@en ;
    rdfs:label "kodiert durch"@de .

# --- Brückenrelationen: Institutio → Nexus (Typifizierung) ---

sdata:typifies a owl:ObjectProperty ;
    owl:equivalentProperty min:typifies ;
    rdfs:label "typifies"@en ;
    rdfs:label "typifiziert"@de .

sdata:typifiedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:typifiedBy ;
    rdfs:label "typified by"@en ;
    rdfs:label "typifiziert durch"@de .

# --- Intra-Forma: Institutio → Forma (Bündelung) ---

sdata:comprises a owl:ObjectProperty ;
    owl:equivalentProperty min:comprises ;
    rdfs:label "comprises"@en ;
    rdfs:label "umfasst"@de .

sdata:comprisedBy a owl:ObjectProperty ;
    owl:equivalentProperty min:comprisedBy ;
    rdfs:label "comprised by"@en ;
    rdfs:label "umfasst durch"@de .

# --- Reflexive Meta-Ebene ---

sdata:describesOntologyTerm a owl:ObjectProperty ;
    owl:equivalentProperty min:describesOntologyTerm ;
    rdfs:label "describes ontology term"@en ;
    rdfs:label "beschreibt Ontologieterm"@de .

# --- Datatype-Property-Fassaden ---

sdata:hasIdentifier a owl:DatatypeProperty ;
    owl:equivalentProperty min:hasIdentifier ;
    rdfs:label "has identifier"@en .

sdata:hasName a owl:DatatypeProperty ;
    owl:equivalentProperty min:hasName ;
    rdfs:label "has name"@en .

sdata:hasTimestamp a owl:DatatypeProperty ;
    owl:equivalentProperty min:hasTimestamp ;
    rdfs:label "has timestamp"@en .

sdata:hasDescription a owl:DatatypeProperty ;
    owl:equivalentProperty min:hasDescription ;
    rdfs:label "has description"@en .

sdata:hasStatus a owl:DatatypeProperty ;
    owl:equivalentProperty min:hasStatus ;
    rdfs:label "has status"@en .

# --- Annotation-Property-Fassaden ---

sdata:causalityMode a owl:AnnotationProperty ;
    owl:equivalentProperty min:causalityMode ;
    rdfs:label "causality mode"@en ;
    rdfs:label "Kausalitätsmodus"@de .

sdata:efficacyMode a owl:AnnotationProperty ;
    owl:equivalentProperty min:efficacyMode ;
    rdfs:label "efficacy mode"@en ;
    rdfs:label "Wirksamkeitsmodus"@de .


# #############################################################################
#
#   TEIL Ia — MIN-KATEGORIEN ALS sdata:-KLASSEN-FASSADEN (7)
#
# #############################################################################

sdata:Object a owl:Class ;
    rdfs:subClassOf min:Object ;
    rdfs:label "Object"@en ;
    rdfs:label "Objekt"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Fassade für min:Object. Das, was da ist.
    Materielle Persistenz.

    Direkte Instanziierung nur für Site.
    Alle anderen physischen Dinge sind Agents
    (Hardware, Material, Substance, Specimen, Person)."""@de .

sdata:Agent a owl:Class ;
    rdfs:subClassOf min:Agent ;
    rdfs:label "Agent"@en ;
    rdfs:label "Agent"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Fassade für min:Agent. Das, was handelt.
    Selektive Handlungsfähigkeit. Querkategorie.
    Co-Typisierung Pflicht: Agent ⊑ Nexus ⊔ Forma.

    DESIGN-PRINZIP: Zustand ≠ Typ.
    Ob ein Agent gerade aktiv ist, gehört in
    sdata:hasStatus, nicht in die Klassenhierarchie."""@de .

sdata:Lex a owl:Class ;
    rdfs:subClassOf min:Lex ;
    rdfs:label "Lex"@en ;
    rdfs:label "Lex"@de ;
    sdata:efficacyMode "lawful" ;
    rdfs:comment """Fassade für min:Lex. Das, was immer gilt.
    Universelle Gültigkeit. Erhaltungssätze,
    Hauptsätze der Thermodynamik. Dünn, aber
    strukturell tragend für First Principle Thinking."""@de .

sdata:Structura a owl:Class ;
    rdfs:subClassOf min:Structura ;
    rdfs:label "Structura"@en ;
    rdfs:label "Structura"@de ;
    sdata:efficacyMode "structural" ;
    rdfs:comment """Fassade für min:Structura. Formale Struktur."""@de .

sdata:Possibile a owl:Class ;
    rdfs:subClassOf min:Possibile ;
    rdfs:label "Possibile"@en ;
    rdfs:label "Possibile"@de ;
    sdata:efficacyMode "modal" ;
    rdfs:comment """Fassade für min:Possibile. Möglichkeitsraum."""@de .

sdata:Norma a owl:Class ;
    rdfs:subClassOf min:Norma ;
    rdfs:label "Norma"@en ;
    rdfs:label "Norma"@de ;
    sdata:efficacyMode "normative" ;
    rdfs:comment """Fassade für min:Norma. Anforderung."""@de .

sdata:Institutio a owl:Class ;
    rdfs:subClassOf min:Institutio ;
    rdfs:label "Institutio"@en ;
    rdfs:label "Institutio"@de ;
    sdata:efficacyMode "institutional" ;
    rdfs:comment """Fassade für min:Institutio. Kollektive Anerkennung."""@de .


# #############################################################################
#
#   TEIL II — OBJECT-HIERARCHIE (1)
#
#   Site ist das einzige reine Object ohne Agency.
#   Hardware, Material, Substance, Specimen → Agent ∩ Object.
#
# #############################################################################

sdata:Site a owl:Class ;
    rdfs:subClassOf sdata:Object ;
    rdfs:label "Site"@en ;
    rdfs:label "Standort"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Physischer Standort. Verortung via sdata:locatedAt.
    Besteht den Selektivitätstest nicht — verortet nur.
    Einziges direkt instanziierbares Object ohne Agency."""@de ;
    skos:example "Werk Duisburg, Presswerk Leipzig, Recyclinganlage Hamburg."@de .


# #############################################################################
#
#   TEIL III — DATA-HIERARCHIE (10)
#
#   ResultFile eliminiert — Data + DataFormat reicht.
#   hasFormat eliminiert — typifiedBy DataFormat.
#   DigitalTwin → Agent ∩ Data ⊂ Software (TEIL IV).
#
# #############################################################################

sdata:Data a owl:Class ;
    rdfs:subClassOf min:Data ;
    rdfs:label "Data"@en ;
    rdfs:label "Daten"@de ;
    sdata:causalityMode "mediated" ;
    rdfs:comment """Domänenspezifische Daten. Wirkt nur über Agent.
    Persistierungsformat über sdata:typifiedBy → DataFormat.
    Dokumente, Dateien, Inputdecks — alles Data."""@de ;
    skos:example "Messdaten, Werkstoffdatenblatt, CAD-Modell, LS-DYNA Inputdeck."@de .

sdata:Identifier a owl:Class ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Identifier"@en ;
    rdfs:label "Identifikator"@de ;
    rdfs:comment "Reifizierter Identifier. Scheme, Value, Issuer, Registry."@de ;
    skos:example "GTIN, DID (did:web), DOI, VDA-Teilenummer, UUID."@de .

sdata:Result a owl:Class ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Result"@en ;
    rdfs:label "Ergebnis"@de ;
    rdfs:comment """Semantisches Ergebnis-Bündel. Eigenes Axiom:
    assessesRequirement + assessmentOutcome.
    Doppeltypisierung Result ∩ VerifiableCredential möglich.
    Persistierung über sdata:typifiedBy → DataFormat."""@de ;
    skos:example "Zugversuchsergebnis, FEM-Ergebnis, Compliance-Bewertung."@de .

sdata:ProductPassport a owl:Class ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Product Passport"@en ;
    rdfs:label "Produktpass"@de ;
    rdfs:comment """Produktpass als Data-Artefakt.
    Versionskette via sdata:supersedes."""@de ;
    skos:example "Materialzeugnis EN 10204, Batterie-Pass, EPD, Stahl-DPP."@de .

sdata:DigitalProductPassport a owl:Class ;
    rdfs:subClassOf sdata:ProductPassport ;
    rdfs:label "Digital Product Passport"@en ;
    rdfs:label "Digitaler Produktpass"@de ;
    skos:altLabel "DPP"@en ;
    rdfs:comment """ESPR-konformer digitaler Produktpass.
    Doppeltypisierung mit VerifiableCredential ist Regelfall."""@de ;
    skos:example "ESPR-DPP, Batterie-Pass (EU 2023/1542), Textil-Pass."@de .

sdata:VerifiableCredential a owl:Class ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Verifiable Credential"@en ;
    rdfs:comment "Signiertes Credential. W3C VC Data Model."@de ;
    skos:example "Signiertes Materialzeugnis, DPP als VC."@de .

sdata:VerifiablePresentation a owl:Class ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Verifiable Presentation"@en ;
    rdfs:comment "Bündel von VCs. Selektive Offenlegung."@de ;
    skos:example "DPP-Präsentation an Recycler."@de .

sdata:Proof a owl:Class ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Proof"@en ;
    rdfs:label "Beweis"@de ;
    rdfs:comment "Kryptographische Signatur."@de ;
    skos:example "Ed25519-Signatur, ECDSA-Signatur."@de .

sdata:CryptographicKey a owl:Class ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Cryptographic Key"@en ;
    rdfs:label "Kryptographischer Schlüssel"@de ;
    rdfs:comment "Schlüsselmaterial. sdata:encodes ein Model."@de ;
    skos:example "Ed25519 Public Key, ECDSA Private Key."@de .

sdata:BillOfMaterials a owl:Class ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Bill of Materials"@en ;
    rdfs:label "Stückliste"@de ;
    rdfs:comment """Stückliste als Data. sdata:describes ein physisches Ding.
    Rekursiv via sdata:hasComponent."""@de ;
    skos:example "Fahrzeug-BOM, Batterie-BOM, Elektronik-BOM."@de .


# #############################################################################
#
#   TEIL IV — AGENT-HIERARCHIE (9)
#
#   Person:           Agent ∩ Object      | material
#   Hardware:         Agent ∩ Object      | material
#   Material:         Agent ∩ Object      | material
#   Substance:        Agent ∩ Object      | material
#   Specimen:         Agent ∩ Object      | material
#   Software:         Agent ∩ Data        | informational
#   DigitalTwin:      ⊂ Software          | informational
#   Organization:     Agent ∩ Institutio  | institutional
#   EnvironmentAgent: Agent ∩ Process     | kausal
#
# #############################################################################

sdata:Person a owl:Class ;
    rdfs:subClassOf sdata:Agent ;
    rdfs:subClassOf sdata:Object ;
    rdfs:label "Person"@en ;
    rdfs:label "Person"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Mensch als handelnder Agent. Agent ∩ Object.
    Identitätskriterium: materiale Kontinuität."""@de ;
    skos:example "Prüfer, Konstrukteur, Werker, Laborant."@de .

sdata:Hardware a owl:Class ;
    rdfs:subClassOf sdata:Agent ;
    rdfs:subClassOf sdata:Object ;
    rdfs:label "Hardware"@en ;
    rdfs:label "Hardware"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Physisches Gerät, Maschine, Bauteil, Werkzeug —
    IMMER Agent. Agent ∩ Object.
    Identitätskriterium: materiale Kontinuität.

    Alles Physische, das handeln KANN, ist Hardware.
    "Ist ein Produkt" kommt über sdata:typifiedBy →
    sdata:ProductType.

    Ob aktiv: sdata:hasStatus.
    Klassifizierung: sdata:ProductType."""@de ;
    skos:example "Presse, Ofen, Prüfmaschine, Sensor, Werkzeug, Roboterarm, Seitenteil, Hammer, Felge."@de .

sdata:Material a owl:Class ;
    rdfs:subClassOf sdata:Agent ;
    rdfs:subClassOf sdata:Object ;
    rdfs:label "Material"@en ;
    rdfs:label "Werkstoff"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Werkstoff als Agent. Wirkt selektiv:
    DC04 verfestigt unter Zug, HC340LA widersteht
    höherer Last, AlSi10Mg leitet Wärme anders als CFK.
    Agent ∩ Object. Identität: material.

    Material = werkstofftechnisch (Gefüge, Zusammensetzung,
    Verarbeitungsgeschichte).
    Substance = stofflich-regulatorisch (CAS, REACH).
    Dasselbe Blech HAT ein Material und ENTHÄLT Substances.

    Klassifizierung: sdata:MaterialGrade."""@de ;
    skos:example "HC340LA, PP-GF30, AlSi10Mg, CFK-Prepreg, Recyclat."@de .

sdata:Substance a owl:Class ;
    rdfs:subClassOf sdata:Agent ;
    rdfs:subClassOf sdata:Object ;
    rdfs:label "Substance"@en ;
    rdfs:label "Substanz"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Chemischer Stoff als Agent. Wirkt selektiv:
    Mangan härtet, Chrom-VI schädigt.
    Agent ∩ Object. Identität: material.
    Regulatorisch: REACH/RoHS/ESPR."""@de ;
    skos:example "Mangan (CAS 7439-96-5), Chrom-VI (SVHC), Blei (RoHS)."@de .

sdata:Specimen a owl:Class ;
    rdfs:subClassOf sdata:Agent ;
    rdfs:subClassOf sdata:Object ;
    rdfs:label "Specimen"@en ;
    rdfs:label "Probe"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Prüfkörper als Agent. Wirkt selektiv:
    widersteht Last, versagt lokal, kann Messeinrichtung
    zerstören. Agent ∩ Object. Identität: material.
    Provenienz via sdata:sampledFrom."""@de ;
    skos:example "Flachzugprobe (DIN 50125 Typ H), Rundprobe, Kerbschlagprobe."@de .

sdata:Software a owl:Class ;
    rdfs:subClassOf sdata:Agent ;
    rdfs:subClassOf sdata:Data ;
    rdfs:label "Software"@en ;
    rdfs:label "Software"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Software — IMMER Agent. Agent ∩ Data.
    Identitätskriterium: informationale Identität.
    Neue Gewichte = neuer Agent.

    Reine Installationsdatei ohne Agency ist sdata:Data.

    Klassifizierung: sdata:ProductType."""@de ;
    skos:example "AutoForm R10, Abaqus 2024, LS-DYNA R14, PostgreSQL, openLCA."@de .

sdata:DigitalTwin a owl:Class ;
    rdfs:subClassOf sdata:Software ;
    rdfs:label "Digital Twin"@en ;
    rdfs:label "Digitaler Zwilling"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Digitaler Zwilling — Software-Agent, der ein
    physisches Gegenstück beschreibt und dessen Verhalten
    vorhersagt. Spezialisierung von Software (Agent ∩ Data).
    Semantischer Unterschied: DigitalTwin sdata:describes
    immer ein physisches Ding."""@de ;
    skos:example "FEM-basierter DZ, Predictive-Maintenance-DZ, Prozess-DZ."@de .

sdata:Organization a owl:Class ;
    rdfs:subClassOf sdata:Agent ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Organization"@en ;
    rdfs:label "Organisation"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Agent ∩ Institutio.
    Identitätskriterium: institutionelle Identität.
    sdata:LegalEntity bleibt für Fälle ohne Agency."""@de ;
    skos:example "Stahlwerk, Prüflabor, Zertifizierer, OEM, Recycler."@de .

sdata:EnvironmentAgent a owl:Class ;
    rdfs:subClassOf sdata:Agent ;
    rdfs:subClassOf sdata:Process ;
    rdfs:label "Environment Agent"@en ;
    rdfs:label "Umwelt-Agent"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment """Natürlicher Prozess mit selektiver Wirkung.
    Agent ∩ Process. Selektivitätstest:
    Korrosion greift bestimmte Korngrenzen an → Agent.
    Tornado transformiert alles → kein Agent."""@de ;
    skos:example "Korrosion, UV-Strahlung, Feuchtigkeit."@de .


# #############################################################################
#
#   TEIL V — PROCESS (1), BOUNDARY (1)
#
# #############################################################################

sdata:Process a owl:Class ;
    rdfs:subClassOf min:Process ;
    rdfs:label "Process"@en ;
    rdfs:label "Prozess"@de ;
    sdata:causalityMode "dispositional" ;
    rdfs:comment "Typisierung über sdata:ProcessType."@de ;
    skos:example "Tiefziehen, Zugversuch, FEM-Simulation, LCA-Studie."@de .

sdata:Boundary a owl:Class ;
    rdfs:subClassOf min:Boundary ;
    rdfs:label "Boundary"@en ;
    rdfs:label "Grenze"@de ;
    sdata:causalityMode "relational" ;
    rdfs:comment "Typisierung über sdata:BoundaryType."@de ;
    skos:example "Übergangswiderstand, Reibung, Adhäsion, Korngrenze."@de .


# #############################################################################
#
#   TEIL VI — FORMA: LEX (1), STRUCTURA (1), POSSIBILE (1)
#
# #############################################################################

sdata:Law a owl:Class ;
    rdfs:subClassOf sdata:Lex ;
    rdfs:label "Law"@en ;
    rdfs:label "Gesetz"@de ;
    sdata:efficacyMode "lawful" ;
    rdfs:comment """Universelles Gesetz. Gilt ausnahmslos.
    Kein Gegenbeispiel möglich. Fundament für FPT.
    Dünn: nur Erhaltungssätze und Hauptsätze.
    Hooke, Fick, Fourier sind Modelle, nicht Gesetze."""@de ;
    skos:example "Energieerhaltung, Massenerhaltung, Entropiezunahme, Impulserhaltung."@de .

sdata:Model a owl:Class ;
    rdfs:subClassOf sdata:Structura ;
    rdfs:label "Model"@en ;
    rdfs:label "Modell"@de ;
    sdata:efficacyMode "structural" ;
    rdfs:comment """Formale Approximation. Kann nützlich sein,
    muss nicht stimmen. Hat einen Gültigkeitsbereich.
    Typisierung über sdata:ModelType."""@de ;
    skos:example "Hooke, von-Mises, Johnson-Cook, Fick, Fourier, ReCiPe, Ed25519, LSTM."@de .

sdata:Scenario a owl:Class ;
    rdfs:subClassOf sdata:Possibile ;
    rdfs:label "Scenario"@en ;
    rdfs:label "Szenario"@de ;
    sdata:efficacyMode "modal" ;
    skos:example "Versagensszenario, FMEA-Zeile, Designalternative."@de .


# #############################################################################
#
#   TEIL VII — FORMA: NORMA (1)
#
# #############################################################################

sdata:Requirement a owl:Class ;
    rdfs:subClassOf sdata:Norma ;
    rdfs:label "Requirement"@en ;
    rdfs:label "Anforderung"@de ;
    sdata:efficacyMode "normative" ;
    rdfs:comment """ATOMARE Anforderung oder Grenzwert. Bündelung
    zu Specification oder Regulation via sdata:comprises."""@de ;
    skos:example "Rm ≥ 340 MPa, Ra ≤ 1.6 µm, FU: 1 kg Stahl ab Werk."@de .


# #############################################################################
#
#   TEIL VIII — FORMA: INSTITUTIO (9)
#
# #############################################################################

sdata:Certification a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Certification"@en ;
    rdfs:label "Zertifizierung"@de ;
    sdata:efficacyMode "institutional" ;
    skos:example "ISO 9001, EN 10204 3.1, CE-Kennzeichnung."@de .

sdata:Accreditation a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Accreditation"@en ;
    rdfs:label "Akkreditierung"@de ;
    sdata:efficacyMode "institutional" ;
    skos:example "DAkkS-Akkreditierung, UKAS."@de .

sdata:Registry a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Registry"@en ;
    rdfs:label "Register"@de ;
    sdata:efficacyMode "institutional" ;
    skos:example "Catena-X Registry, GAIA-X Registry."@de .

sdata:TrustFramework a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Trust Framework"@en ;
    rdfs:label "Vertrauensrahmen"@de ;
    sdata:efficacyMode "institutional" ;
    skos:example "Catena-X, GAIA-X, EBSI, IBU EPD-Programm."@de .

sdata:Regulation a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Regulation"@en ;
    rdfs:label "Verordnung"@de ;
    sdata:efficacyMode "institutional" ;
    rdfs:comment """Regulatorisches Rahmenwerk. BÜNDELT atomare
    Anforderungen via sdata:comprises."""@de ;
    skos:example "ESPR, CBAM, REACH, RoHS, EU-Taxonomie."@de .

sdata:Specification a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Specification"@en ;
    rdfs:label "Spezifikation"@de ;
    sdata:efficacyMode "institutional" ;
    rdfs:comment """Technische Spezifikation oder Norm. BÜNDELT atomare
    Anforderungen via sdata:comprises."""@de ;
    skos:example "EN 10025-2, DIN EN ISO 6892-1, ISO 14040."@de .

sdata:LifecyclePhase a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Lifecycle Phase"@en ;
    rdfs:label "Lebenszyklusphase"@de ;
    sdata:efficacyMode "institutional" ;
    rdfs:comment """Konventionelle Lebenszykluseinteilung.
    Existiert durch Anerkennung der LCA/ESPR-Community."""@de ;
    skos:example "Rohstoffgewinnung, Fertigung, Nutzung, End-of-Life."@de .

sdata:LegalEntity a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Legal Entity"@en ;
    rdfs:label "Juristische Person"@de ;
    sdata:efficacyMode "institutional" ;
    rdfs:comment """Juristische Person OHNE Agency.
    Aktive Unternehmen: sdata:Organization."""@de ;
    skos:example "Aufgelöste GmbH, historische Institution."@de .


# #############################################################################
#
#   TEIL IX — FORMA: TYPUS (6)
#
# #############################################################################

sdata:Typus a owl:Class ;
    rdfs:subClassOf sdata:Institutio ;
    rdfs:label "Typus"@en ;
    rdfs:label "Typus"@de ;
    sdata:efficacyMode "institutional" ;
    rdfs:comment """Konventionelle Wesensbestimmung. Bündelt Forma.
    Typifiziert Nexus via sdata:typifies."""@de .

sdata:MaterialGrade a owl:Class ;
    rdfs:subClassOf sdata:Typus ;
    rdfs:label "Material Grade"@en ;
    rdfs:label "Werkstoffsorte"@de ;
    skos:example "DC04, HC340LA, AlSi10Mg, PP-GF30, X5CrNi18-10."@de .

sdata:ProcessType a owl:Class ;
    rdfs:subClassOf sdata:Typus ;
    rdfs:label "Process Type"@en ;
    rdfs:label "Verfahrenstyp"@de ;
    skos:example "Zugversuch nach ISO 6892-1, Tiefziehen, Crashsimulation."@de .

sdata:ProductType a owl:Class ;
    rdfs:subClassOf sdata:Typus ;
    rdfs:label "Product Type"@en ;
    rdfs:label "Produkttyp"@de ;
    rdfs:comment """Wesensbestimmung eines Produkts, Geräts oder
    Software-Typs. Einheitlicher Typus für Hardware,
    Software und alle anderen typifizierbaren Nexus.
    Ersetzt die ehemaligen Klassen Product, HardwareType
    und SoftwareType."""@de ;
    skos:example "Seitenteil, B-Säule, Felge, Universalprüfmaschine, Hydraulische Presse, FE-Solver, CAD-System, LCA-Software."@de .

sdata:DataFormat a owl:Class ;
    rdfs:subClassOf sdata:Typus ;
    rdfs:label "Data Format"@en ;
    rdfs:label "Datenformat"@de ;
    rdfs:comment """Wesensbestimmung eines Dateiformats. Ersetzt
    die ehemalige DP hasFormat und die Klasse ResultFile."""@de ;
    skos:example "STEP AP214, JT, VTU, CSV (RFC 4180), JSON-LD, Parquet, PDF."@de .



sdata:BoundaryType a owl:Class ;
    rdfs:subClassOf sdata:Typus ;
    rdfs:label "Boundary Type"@en ;
    rdfs:label "Grenzflächentyp"@de ;
    skos:example "Coulomb-Reibung, Σ3-CSL-Korngrenze, thermischer Kontaktwiderstand."@de .

sdata:ModelType a owl:Class ;
    rdfs:subClassOf sdata:Typus ;
    rdfs:label "Model Type"@en ;
    rdfs:label "Modelltyp"@de ;
    skos:example "Materialmodell, Kryptoalgorithmus, ML-Architektur, DB-Schema."@de .


# #############################################################################
#
#   TEIL X — EIGENE sdata OBJECT PROPERTIES (30)
#
# #############################################################################

sdata:hasMaterial a owl:ObjectProperty ;
    rdfs:label "has material"@en ;
    rdfs:domain min:Object ;
    rdfs:range sdata:Material ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:usesTool a owl:ObjectProperty ;
    rdfs:label "uses tool"@en ;
    rdfs:domain sdata:Process ;
    rdfs:range sdata:Hardware ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:usesSoftware a owl:ObjectProperty ;
    rdfs:label "uses software"@en ;
    rdfs:domain sdata:Process ;
    rdfs:range sdata:Software ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:certifies a owl:ObjectProperty ;
    rdfs:label "certifies"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range min:Nexus ;
    rdfs:subPropertyOf sdata:describes .

sdata:succeeds a owl:ObjectProperty ;
    rdfs:label "succeeds"@en ;
    rdfs:domain sdata:Process ;
    rdfs:range sdata:Process ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:precedes a owl:ObjectProperty ;
    rdfs:label "precedes"@en ;
    rdfs:domain sdata:Process ;
    rdfs:range sdata:Process ;
    owl:inverseOf sdata:succeeds ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:hasData a owl:ObjectProperty ;
    rdfs:label "has data"@en ;
    rdfs:domain min:Nexus ;
    rdfs:range sdata:Data ;
    rdfs:subPropertyOf sdata:describedBy .

sdata:producedBy a owl:ObjectProperty ;
    rdfs:label "produced by"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range sdata:Process ;
    rdfs:subPropertyOf sdata:generatedBy .

sdata:certifiedUnder a owl:ObjectProperty ;
    rdfs:label "certified under"@en ;
    rdfs:domain min:Nexus ;
    rdfs:range sdata:Certification ;
    rdfs:subPropertyOf sdata:realizes .

sdata:identifiedBy a owl:ObjectProperty ;
    rdfs:label "identified by"@en ;
    rdfs:domain min:Entity ;
    rdfs:range sdata:Identifier .

sdata:hasIssuer a owl:ObjectProperty ;
    rdfs:label "has issuer"@en ;
    rdfs:domain sdata:Identifier ;
    rdfs:range min:Agent ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:signedBy a owl:ObjectProperty ;
    rdfs:label "signed by"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range min:Agent ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:locatedAt a owl:ObjectProperty ;
    rdfs:label "located at"@en ;
    rdfs:domain min:Nexus ;
    rdfs:range sdata:Site ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:registeredIn a owl:ObjectProperty ;
    rdfs:label "registered in"@en ;
    rdfs:domain sdata:Identifier ;
    rdfs:range sdata:Registry ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:hasCustodian a owl:ObjectProperty ;
    rdfs:label "has custodian"@en ;
    rdfs:domain min:Nexus ;
    rdfs:range min:Agent ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:supersedes a owl:ObjectProperty ;
    rdfs:label "supersedes"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range sdata:Data ;
    rdfs:subPropertyOf sdata:derivedFrom .

sdata:supersededBy a owl:ObjectProperty ;
    rdfs:label "superseded by"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range sdata:Data ;
    owl:inverseOf sdata:supersedes .

sdata:assessesRequirement a owl:ObjectProperty ;
    rdfs:label "assesses requirement"@en ;
    rdfs:domain sdata:Result ;
    rdfs:range sdata:Requirement ;
    rdfs:subPropertyOf sdata:realizes .

sdata:sampledFrom a owl:ObjectProperty ;
    rdfs:label "sampled from"@en ;
    rdfs:domain sdata:Specimen ;
    rdfs:range min:Object ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:containsSubstance a owl:ObjectProperty ;
    rdfs:label "contains substance"@en ;
    rdfs:domain min:Object ;
    rdfs:range sdata:Substance ;
    rdfs:subPropertyOf sdata:nexusWith .

sdata:hasBOM a owl:ObjectProperty ;
    rdfs:label "has bill of materials"@en ;
    rdfs:domain min:Object ;
    rdfs:range sdata:BillOfMaterials ;
    rdfs:subPropertyOf sdata:describedBy .

sdata:specifies a owl:ObjectProperty ;
    rdfs:label "specifies"@en ;
    rdfs:domain sdata:Specification ;
    rdfs:range min:Nexus ;
    rdfs:subPropertyOf sdata:constrains .

sdata:regulates a owl:ObjectProperty ;
    rdfs:label "regulates"@en ;
    rdfs:label "reguliert"@de ;
    rdfs:domain sdata:Regulation ;
    rdfs:range min:Nexus ;
    rdfs:subPropertyOf sdata:constrains .

sdata:requiresPhase a owl:ObjectProperty ;
    rdfs:label "requires phase"@en ;
    rdfs:label "erfordert Phase"@de ;
    rdfs:domain sdata:Process ;
    rdfs:range sdata:LifecyclePhase ;
    rdfs:subPropertyOf sdata:realizes .

sdata:issuedBy a owl:ObjectProperty ;
    rdfs:label "issued by"@en ;
    rdfs:label "herausgegeben von"@de ;
    rdfs:domain min:Institutio ;
    rdfs:range min:Agent ;
    rdfs:subPropertyOf sdata:constitutedBy .

sdata:governedBy a owl:ObjectProperty ;
    rdfs:label "governed by"@en ;
    rdfs:label "geregelt durch"@de ;
    rdfs:domain sdata:Process ;
    rdfs:range sdata:Law .

sdata:originatedIn a owl:ObjectProperty ;
    rdfs:label "originated in"@en ;
    rdfs:label "entstanden in"@de ;
    rdfs:domain min:Forma ;
    rdfs:range sdata:Process ;
    rdfs:subPropertyOf sdata:originatedBy .

sdata:hasLegalEntity a owl:ObjectProperty ;
    rdfs:label "has legal entity"@en ;
    rdfs:label "hat juristische Person"@de ;
    rdfs:domain sdata:Organization ;
    rdfs:range sdata:LegalEntity .

sdata:regulatedBy a owl:ObjectProperty ;
    rdfs:label "regulated by"@en ;
    rdfs:label "reguliert durch"@de ;
    rdfs:domain min:Nexus ;
    rdfs:range sdata:Regulation ;
    owl:inverseOf sdata:regulates .

sdata:specifiedBy a owl:ObjectProperty ;
    rdfs:label "specified by"@en ;
    rdfs:label "spezifiziert durch"@de ;
    rdfs:domain min:Nexus ;
    rdfs:range sdata:Specification ;
    owl:inverseOf sdata:specifies .


# #############################################################################
#
#   TEIL XI — EIGENE sdata DATATYPE PROPERTIES (18)
#
#   hasFormat eliminiert — typifiedBy DataFormat reicht.
#
# #############################################################################

sdata:hasVersion a owl:DatatypeProperty ;
    rdfs:label "has version"@en ;
    rdfs:domain min:Nexus ;
    rdfs:range xsd:string .

sdata:hasUUID a owl:DatatypeProperty ;
    rdfs:label "has UUID"@en ;
    rdfs:domain min:Nexus ;
    rdfs:range xsd:string .

sdata:hasStartTime a owl:DatatypeProperty ;
    rdfs:label "has start time"@en ;
    rdfs:domain sdata:Process ;
    rdfs:range xsd:dateTime .

sdata:hasEndTime a owl:DatatypeProperty ;
    rdfs:label "has end time"@en ;
    rdfs:domain sdata:Process ;
    rdfs:range xsd:dateTime .

sdata:hasConfidence a owl:DatatypeProperty ;
    rdfs:label "has confidence"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range xsd:float .

sdata:hasSource a owl:DatatypeProperty ;
    rdfs:label "has source"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range xsd:string .

sdata:hasLocation a owl:DatatypeProperty ;
    rdfs:label "has location"@en ;
    rdfs:domain min:Nexus ;
    rdfs:range xsd:string .

sdata:hasEndpoint a owl:DatatypeProperty ;
    rdfs:label "has endpoint"@en ;
    rdfs:domain min:Nexus ;
    rdfs:range xsd:anyURI .

sdata:hasScheme a owl:DatatypeProperty ;
    rdfs:label "has scheme"@en ;
    rdfs:domain sdata:Identifier ;
    rdfs:range xsd:string .

sdata:hasValue a owl:DatatypeProperty ;
    rdfs:label "has value"@en ;
    rdfs:domain sdata:Identifier ;
    rdfs:range xsd:string .

sdata:hasChecksum a owl:DatatypeProperty ;
    rdfs:label "has checksum"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range xsd:string .

sdata:validFrom a owl:DatatypeProperty ;
    rdfs:label "valid from"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range xsd:dateTime .

sdata:validUntil a owl:DatatypeProperty ;
    rdfs:label "valid until"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range xsd:dateTime .

sdata:revokedAt a owl:DatatypeProperty ;
    rdfs:label "revoked at"@en ;
    rdfs:domain sdata:Data ;
    rdfs:range xsd:dateTime .

sdata:assessmentOutcome a owl:DatatypeProperty ;
    rdfs:label "assessment outcome"@en ;
    rdfs:domain sdata:Result ;
    rdfs:range [
        a rdfs:Datatype ;
        owl:oneOf ( "pass"^^xsd:string "fail"^^xsd:string "inconclusive"^^xsd:string )
    ] .

sdata:hasCASNumber a owl:DatatypeProperty ;
    rdfs:label "has CAS number"@en ;
    rdfs:domain sdata:Substance ;
    rdfs:range xsd:string .

sdata:hasConcentration a owl:DatatypeProperty ;
    rdfs:label "has concentration"@en ;
    rdfs:domain sdata:Substance ;
    rdfs:range xsd:float .

sdata:hasRegulatoryStatus a owl:DatatypeProperty ;
    rdfs:label "has regulatory status"@en ;
    rdfs:domain sdata:Substance ;
    rdfs:range xsd:string .


# #############################################################################
#
#   TEIL XII — DISJUNKTHEIT
#
#   Object-Disjunktheit entfällt (nur Site).
#   Agent-Disjunktheit enthält alle 9 Agent-Klassen.
#
# #############################################################################

[] a owl:AllDisjointClasses ;
    owl:members ( sdata:Person sdata:Hardware sdata:Software
                  sdata:Material sdata:Substance sdata:Specimen
                  sdata:DigitalTwin
                  sdata:Organization sdata:EnvironmentAgent ) .

[] a owl:AllDisjointClasses ;
    owl:members ( sdata:Certification sdata:Accreditation
                  sdata:Registry sdata:TrustFramework
                  sdata:Regulation sdata:Specification
                  sdata:LifecyclePhase sdata:LegalEntity ) .

[] a owl:AllDisjointClasses ;
    owl:members ( sdata:MaterialGrade sdata:ProcessType sdata:ProductType
                  sdata:DataFormat
                  sdata:BoundaryType
                  sdata:ModelType ) .


# #############################################################################
#
#   TEIL XIII — MODELING PATTERNS (1–16)
#
# #############################################################################

# MUSTER 1: Mehrstufiger Herstellungsprozess
#
#   :walzen  a sdata:Process ;
#       sdata:realizes :phase_production ;
#       sdata:succeeds :erzgewinnung ;
#       sdata:hasInput :coil_001 ;
#       sdata:hasOutput :bauteil_001 .
#   :bauteil_001  a sdata:Hardware ;
#       sdata:typifiedBy :seitenteil_typ .
#   :recycling  a sdata:Process ;
#       sdata:realizes :phase_eol ;
#       sdata:hasInput :bauteil_demontiert ;
#       sdata:hasOutput :recyclat_001 .
#   :recyclat_001  a sdata:Material ;
#       sdata:typifiedBy :recyclat_grade .

# MUSTER 2: DPP
#
#   :dpp_001  a sdata:DigitalProductPassport , sdata:VerifiableCredential ;
#       sdata:describes :bauteil_001 ;
#       sdata:encodes :espr_dpp_spec ;
#       sdata:typifiedBy :espr_dpp_spec ;
#       sdata:signedBy :oem_ag ;
#       sdata:identifiedBy :did_dpp_001 .

# MUSTER 3: did:web + Signing
#
#   :did_oem  a sdata:Identifier ;
