#                      sdata:succeeds :walzen ;
#                      min:hasInput :coil_001 ; min:hasOutput :bauteil_001 .
#   :montage       a sdata:Process ; min:realizes :phase_production ;
#                      sdata:succeeds :tiefziehen .
#   :nutzung       a sdata:Process ; min:realizes :phase_use ;
#                      sdata:succeeds :montage .
#   :recycling     a sdata:Process ; min:realizes :phase_eol ;
#                      sdata:succeeds :nutzung ;
#                      min:hasInput :bauteil_demontiert ;
#                      min:hasOutput :recyclat_001 .
#   :recyclat_001  a sdata:Material .

