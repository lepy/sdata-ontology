#   MUSTER 8: Verifikation
# =============================================================================
#
#   :verification  a sdata:Process ;
#       min:hasInput :dpp_001 ;
#       min:hasInput :did_document ;
#       min:performedBy :verifier ;
#       min:hasOutput :verification_result .
#   :verification_result  a sdata:Result ;
#       min:hasStatus "verified" .
#   :catena_x  a sdata:TrustFramework ;
#       min:constitutedBy :consortium ;
#       min:recognizedBy :oem_ag .

# =============================================================================
#   MUSTER 9: Custody-Verlauf (NEU v0.13.1)
#
#   Custody-History lebt im Prozessgraph — kein separates
#   History-Objekt nötig. hasCustodian zeigt den AKTUELLEN Stand.
# =============================================================================
#
#   :bauteil_001  a sdata:Product ;
#       sdata:hasCustodian :stahlwerk_ag ;
#       sdata:locatedAt :werk_duisburg .
#
#   :custody_transfer_01  a sdata:Process ;
#       rdfs:label "Übergabe an OEM" ;
#       min:hasInput :bauteil_001 ;
#       min:performedBy :stahlwerk_ag ;
#       min:hasOutput :bauteil_001_at_oem ;
#       sdata:hasStartTime "2026-02-01T08:00:00Z"^^xsd:dateTime .
#
#   :bauteil_001_at_oem  a sdata:Product ;
#       sdata:hasCustodian :oem_ag ;
#       sdata:locatedAt :presswerk_leipzig ;
#       owl:sameAs :bauteil_001 .   # optionale Identitätsbrücke
#
#   :werk_duisburg  a sdata:Site ;
#       sdata:hasEndpoint "https://gln.example.com/4012345000016"^^xsd:anyURI .
#   :presswerk_leipzig  a sdata:Site .

# =============================================================================
#   MUSTER 10: Gültigkeit und Revocation (NEU v0.13.1)
#
#   Drei Zustände per SPARQL:
#   aktiv:     validFrom ≤ now, revokedAt absent, validUntil absent or > now
#   abgelaufen: validUntil < now
#   revoked:   revokedAt present
# =============================================================================
#
#   :vc_materialzeugnis  a sdata:VerifiableCredential ;
#       sdata:signedBy :pruefinstitut_ag ;
#       sdata:validFrom  "2026-01-15T00:00:00Z"^^xsd:dateTime ;
#       sdata:validUntil "2028-01-15T00:00:00Z"^^xsd:dateTime .
#
#   # Revocation durch Nachfolge-VC:
#   :vc_materialzeugnis_v2  a sdata:VerifiableCredential ;
#       sdata:supersedes :vc_materialzeugnis ;
#       sdata:signedBy :pruefinstitut_ag ;
#       sdata:validFrom  "2026-03-01T00:00:00Z"^^xsd:dateTime .
#
#   # Expliziter Widerruf (z.B. Fehler entdeckt):
#   :vc_fehlerhaft  a sdata:VerifiableCredential ;
#       sdata:revokedAt "2026-02-20T14:30:00Z"^^xsd:dateTime .
#
#   # SPARQL: alle aktiven VCs
#   # SELECT ?vc WHERE {
#   #   ?vc a sdata:VerifiableCredential ;
#   #       sdata:validFrom ?vf .
#   #   FILTER (?vf <= NOW())
#   #   FILTER NOT EXISTS { ?vc sdata:revokedAt ?ra }
#   #   OPTIONAL { ?vc sdata:validUntil ?vu }
#   #   FILTER (!BOUND(?vu) || ?vu > NOW())
#   # }

# =============================================================================
#   MUSTER 11: Explizite Versionskette (NEU v0.13.1)
#
#   supersedes ist subPropertyOf derivedFrom → Versionsnavigation
#   ist SPARQL-kompatibel mit der allgemeinen Provenance-Abfrage.
# =============================================================================
#
#   :dpp_v1  a sdata:ProductPassport ;
#       sdata:hasVersion "1.0.0" ;
#       sdata:validFrom "2025-06-01T00:00:00Z"^^xsd:dateTime .
#
#   :dpp_v2  a sdata:ProductPassport ;
#       sdata:hasVersion "2.0.0" ;
#       sdata:supersedes :dpp_v1 ;          # v2 ersetzt v1
#       sdata:validFrom "2026-01-01T00:00:00Z"^^xsd:dateTime .
#
#   :dpp_v3  a sdata:ProductPassport ;
#       sdata:hasVersion "3.0.0" ;
#       sdata:supersedes :dpp_v2 ;          # v3 ersetzt v2
#       sdata:validFrom "2026-03-04T00:00:00Z"^^xsd:dateTime .
#
#   # Vorwärtsnavigation (supersededBy, automatisch durch OWL inverse):
#   # :dpp_v1 sdata:supersededBy :dpp_v2 .  ← inferiert
#   # :dpp_v2 sdata:supersededBy :dpp_v3 .  ← inferiert

# =============================================================================
#   MUSTER 12: Identifier → Registry → TrustFramework (NEU v0.13.1)
#
#   Vollständiger Vertrauenspfad ohne implizites Namespace-Mapping.
# =============================================================================
#
#   :did_oem  a sdata:Identifier ;
#       sdata:hasScheme "W3C:DID" ;
#       sdata:hasValue "did:web:oem.example.com" ;
#       sdata:hasIssuer :oem_ag ;
#       sdata:registeredIn :catena_x_did_registry ;
#       sdata:validFrom "2025-01-01T00:00:00Z"^^xsd:dateTime .
#
#   :catena_x_did_registry  a sdata:Registry ;
#       min:constitutedBy :catena_x_consortium .
#
#   :catena_x_consortium  a sdata:Organization .
#
#   :catena_x  a sdata:TrustFramework ;
#       min:constitutedBy :catena_x_consortium ;
#       min:hasComponent :catena_x_did_registry .
#
#   # Vertrauenspfad per SPARQL:
#   # SELECT ?tf WHERE {
#   #   :did_oem sdata:registeredIn ?reg .
#   #   ?tf a sdata:TrustFramework ;
#   #       min:hasComponent ?reg .
#   # }

# =============================================================================
#   MUSTER 12b: Vollständiger Compliance-Claim (AssessmentResult)
# =============================================================================
#
#   :req_rm  a sdata:Requirement ;
#       rdfs:label "Rm ≥ 340 MPa" ;
#       skos:notation "HC340LA-Rm" .
#
#   :ar_rm_probe42  a sdata:AssessmentResult , sdata:VerifiableCredential ;
#       sdata:assessesRequirement :req_rm ;
#       sdata:assessmentOutcome "pass" ;
#       min:generatedBy :zugversuch_probe42 ;
#       sdata:signedBy :pruefinstitut_ag ;
#       sdata:validFrom "2026-03-04T10:00:00Z"^^xsd:dateTime ;
#       min:hasComponent :proof_ar_rm_probe42 .
#
#   :result_zugversuch_probe42  a sdata:Result ;
#       min:hasComponent :ar_rm_probe42 ;
#       min:hasComponent :ar_a80_probe42 ;
#       min:generatedBy :zugversuch_probe42 .


# #############################################################################
#
#   INVENTAR v0.13.1
#
#   KLASSEN (35):
#     Object (6): Material, Product, Hardware, Software, Database, Site
#     Data (11): Data, Identifier, Result, AssessmentResult, ResultFile,
#       ProductPassport, DigitalTwin, VerifiableCredential,
#       VerifiablePresentation, Proof, CryptographicKey
#     Agent (5): Person, HardwareAgent, SoftwareAgent,
#       Organization, EnvironmentAgent
#     Process (1): Process
#     Boundary (1): Boundary
#     Lex (1): Law
